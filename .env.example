# ─── LOB Brain — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Required for SSE mode (remote agents) ─────────────────────────────────────
# Master API key to protect your LOB Brain server.
# Use a strong random string (e.g., openssl rand -hex 32).
LAMBDA_BRAIN_API_KEY=your-strong-master-key-here

# ── Optional: Gemini Embeddings ───────────────────────────────────────────────
# Enables high-quality semantic search via Google Gemini text-embedding-004.
# Free tier: 1500 requests/day — https://aistudio.google.com/apikey
# If omitted, falls back to built-in local TF-IDF (no API calls).
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Custom database path ───────────────────────────────────────────
# Defaults to ./brain.db in the current working directory.
# LAMBDA_BRAIN_DB_PATH=/absolute/path/to/your/brain.db
