{
  "name": "lob-brain",
  "version": "1.0.0",
  "description": "LOB AI Brain — MCP Server with λ-Memory decay algorithm",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lob-brain": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:sse": "node dist/index.js --sse --port 3020",
    "dev": "tsx src/index.ts",
    "dev:sse": "tsx src/index.ts --sse --port 3020",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "mcp",
    "ai",
    "memory",
    "lambda",
    "brain"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}